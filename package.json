{
  "name": "companycore",
  "version": "0.1.0",
  "private": true,
  "description": "LuckySparrow Company Core v1 backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc",
    "build:web": "node scripts/clean-react-build.mjs && vite build",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "seed": "tsx prisma/seed.ts",
    "adapter:smoke": "node scripts/adapter-smoke.mjs",
    "agent:training-smoke": "node scripts/agent-training-smoke.mjs",
    "owner-console:ux-smoke": "node scripts/owner-console-ux-smoke.mjs",
    "google-drive:smoke": "node scripts/google-drive-production-smoke.mjs",
    "clickup:bootstrap": "node scripts/clickup-production-bootstrap.mjs",
    "test": "npm run build && npm run prisma:migrate:deploy && node --test \"dist/tests/**/*.test.js\"",
    "validate": "npm run build"
  },
  "dependencies": {
    "@phosphor-icons/web": "^2.1.2",
    "@prisma/client": "^5.22.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "cors": "^2.8.5",
    "daisyui": "^5.5.19",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.11",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "playwright": "^1.59.1",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
