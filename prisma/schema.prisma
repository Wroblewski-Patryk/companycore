generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  todo
  in_progress
  blocked
  done
  archived
}

enum DealStatus {
  open
  won
  lost
  archived
}

enum AgentStatus {
  active
  paused
  retired
}

enum WorkspaceRole {
  owner
}

model User {
  id              String                @id @default(uuid()) @db.Uuid
  email           String                @unique
  name            String?
  passwordHash    String                @map("password_hash")
  ownedWorkspaces Workspace[]           @relation("WorkspaceOwner")
  memberships     WorkspaceMembership[]
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  @@map("users")
}

model Workspace {
  id                           String                        @id @default(uuid()) @db.Uuid
  name                         String
  ownerUserId                  String                        @map("owner_user_id") @db.Uuid
  owner                        User                          @relation("WorkspaceOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  memberships                  WorkspaceMembership[]
  apiKeys                      ApiKey[]
  integrationSettings          IntegrationSetting[]
  projects                     Project[]
  goals                        Goal[]
  targets                      Target[]
  taskLists                    TaskList[]
  tasks                        Task[]
  clients                      Client[]
  pipelineStages               PipelineStage[]
  deals                        Deal[]
  interactions                 Interaction[]
  notes                        Note[]
  decisions                    Decision[]
  agents                       Agent[]
  agentLogs                    AgentLog[]
  events                       Event[]
  operatingAreas               OperatingArea[]
  operatingFolders             OperatingFolder[]
  operatingTables              OperatingTable[]
  externalContainerMappings    ExternalContainerMapping[]
  externalFieldMappings        ExternalFieldMapping[]
  storageLocations             StorageLocation[]
  knowledgeRoots               KnowledgeRoot[]
  automationDefinitions        AutomationDefinition[]
  googleDriveFiles             GoogleDriveFile[]
  googleDriveContentSnapshots  GoogleDriveContentSnapshot[]
  externalWebhookRegistrations ExternalWebhookRegistration[]
  providerEventInbox           ProviderEventInbox[]
  agentEventOutbox             AgentEventOutbox[]
  createdAt                    DateTime                      @default(now()) @map("created_at")
  updatedAt                    DateTime                      @updatedAt @map("updated_at")

  @@map("workspaces")
}

model OperatingArea {
  id                        String                     @id @default(uuid()) @db.Uuid
  workspaceId               String                     @map("workspace_id") @db.Uuid
  workspace                 Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  key                       String
  name                      String
  description               String?
  position                  Int                        @default(0)
  folders                   OperatingFolder[]
  tables                    OperatingTable[]
  externalContainerMappings ExternalContainerMapping[]
  storageLocations          StorageLocation[]
  knowledgeRoots            KnowledgeRoot[]
  googleDriveFiles          GoogleDriveFile[]
  automationDefinitions     AutomationDefinition[]
  createdAt                 DateTime                   @default(now()) @map("created_at")
  updatedAt                 DateTime                   @updatedAt @map("updated_at")

  @@unique([workspaceId, key])
  @@index([workspaceId, position])
  @@map("operating_areas")
}

model OperatingFolder {
  id                        String                     @id @default(uuid()) @db.Uuid
  workspaceId               String                     @map("workspace_id") @db.Uuid
  workspace                 Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  areaId                    String                     @map("area_id") @db.Uuid
  area                      OperatingArea              @relation(fields: [areaId], references: [id], onDelete: Cascade)
  key                       String
  name                      String
  description               String?
  source                    String                     @default("companycore")
  externalId                String?                    @map("external_id")
  tables                    OperatingTable[]
  externalContainerMappings ExternalContainerMapping[]
  storageLocations          StorageLocation[]
  knowledgeRoots            KnowledgeRoot[]
  googleDriveFiles          GoogleDriveFile[]
  automationDefinitions     AutomationDefinition[]
  createdAt                 DateTime                   @default(now()) @map("created_at")
  updatedAt                 DateTime                   @updatedAt @map("updated_at")

  @@unique([workspaceId, key])
  @@unique([workspaceId, source, externalId])
  @@index([workspaceId, areaId])
  @@map("operating_folders")
}

model OperatingTable {
  id                        String                     @id @default(uuid()) @db.Uuid
  workspaceId               String                     @map("workspace_id") @db.Uuid
  workspace                 Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  areaId                    String                     @map("area_id") @db.Uuid
  area                      OperatingArea              @relation(fields: [areaId], references: [id], onDelete: Cascade)
  folderId                  String?                    @map("folder_id") @db.Uuid
  folder                    OperatingFolder?           @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tableName                 String                     @map("table_name")
  apiSlug                   String                     @map("api_slug")
  name                      String
  description               String?
  source                    String                     @default("companycore")
  externalId                String?                    @map("external_id")
  syncPolicy                Json                       @default("{}") @map("sync_policy")
  externalContainerMappings ExternalContainerMapping[]
  externalFieldMappings     ExternalFieldMapping[]
  storageLocations          StorageLocation[]
  knowledgeRoots            KnowledgeRoot[]
  googleDriveFiles          GoogleDriveFile[]
  automationDefinitions     AutomationDefinition[]
  createdAt                 DateTime                   @default(now()) @map("created_at")
  updatedAt                 DateTime                   @updatedAt @map("updated_at")

  @@unique([workspaceId, apiSlug])
  @@unique([workspaceId, tableName])
  @@unique([workspaceId, source, externalId])
  @@index([workspaceId, areaId])
  @@index([workspaceId, folderId])
  @@map("operating_tables")
}

model ExternalContainerMapping {
  id          String           @id @default(uuid()) @db.Uuid
  workspaceId String           @map("workspace_id") @db.Uuid
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  provider    String
  entityType  String           @map("entity_type")
  externalId  String           @map("external_id")
  name        String?
  areaId      String?          @map("area_id") @db.Uuid
  area        OperatingArea?   @relation(fields: [areaId], references: [id], onDelete: SetNull)
  folderId    String?          @map("folder_id") @db.Uuid
  folder      OperatingFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tableId     String?          @map("table_id") @db.Uuid
  table       OperatingTable?  @relation(fields: [tableId], references: [id], onDelete: SetNull)
  raw         Json?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@unique([workspaceId, provider, entityType, externalId])
  @@index([workspaceId, provider, entityType])
  @@map("external_container_mappings")
}

model ExternalFieldMapping {
  id          String          @id @default(uuid()) @db.Uuid
  workspaceId String          @map("workspace_id") @db.Uuid
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  provider    String
  externalId  String          @map("external_id")
  name        String
  fieldType   String?         @map("field_type")
  tableId     String?         @map("table_id") @db.Uuid
  table       OperatingTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)
  nativeField String?         @map("native_field")
  typeConfig  Json?           @map("type_config")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@unique([workspaceId, provider, externalId])
  @@index([workspaceId, provider])
  @@map("external_field_mappings")
}

model StorageLocation {
  id               String            @id @default(uuid()) @db.Uuid
  workspaceId      String            @map("workspace_id") @db.Uuid
  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  areaId           String?           @map("area_id") @db.Uuid
  area             OperatingArea?    @relation(fields: [areaId], references: [id], onDelete: SetNull)
  folderId         String?           @map("folder_id") @db.Uuid
  folder           OperatingFolder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tableId          String?           @map("table_id") @db.Uuid
  table            OperatingTable?   @relation(fields: [tableId], references: [id], onDelete: SetNull)
  provider         String
  name             String
  locator          Json
  googleDriveFiles GoogleDriveFile[]
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  @@index([workspaceId, provider])
  @@map("storage_locations")
}

model KnowledgeRoot {
  id               String            @id @default(uuid()) @db.Uuid
  workspaceId      String            @map("workspace_id") @db.Uuid
  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  areaId           String?           @map("area_id") @db.Uuid
  area             OperatingArea?    @relation(fields: [areaId], references: [id], onDelete: SetNull)
  folderId         String?           @map("folder_id") @db.Uuid
  folder           OperatingFolder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tableId          String?           @map("table_id") @db.Uuid
  table            OperatingTable?   @relation(fields: [tableId], references: [id], onDelete: SetNull)
  provider         String
  name             String
  locator          Json
  googleDriveFiles GoogleDriveFile[]
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  @@index([workspaceId, provider])
  @@map("knowledge_roots")
}

model AutomationDefinition {
  id          String           @id @default(uuid()) @db.Uuid
  workspaceId String           @map("workspace_id") @db.Uuid
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  areaId      String?          @map("area_id") @db.Uuid
  area        OperatingArea?   @relation(fields: [areaId], references: [id], onDelete: SetNull)
  folderId    String?          @map("folder_id") @db.Uuid
  folder      OperatingFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tableId     String?          @map("table_id") @db.Uuid
  table       OperatingTable?  @relation(fields: [tableId], references: [id], onDelete: SetNull)
  provider    String?
  triggerType String           @map("trigger_type")
  name        String
  enabled     Boolean          @default(true)
  config      Json             @default("{}")
  lastRunAt   DateTime?        @map("last_run_at")
  lastError   String?          @map("last_error")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@index([workspaceId, provider])
  @@map("automation_definitions")
}

model GoogleDriveFile {
  id                String                       @id @default(uuid()) @db.Uuid
  workspaceId       String                       @map("workspace_id") @db.Uuid
  workspace         Workspace                    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  provider          String                       @default("google_drive")
  externalId        String                       @map("external_id")
  name              String
  mimeType          String                       @map("mime_type")
  driveId           String?                      @map("drive_id")
  parentExternalId  String?                      @map("parent_external_id")
  isFolder          Boolean                      @default(false) @map("is_folder")
  trashed           Boolean                      @default(false)
  webViewLink       String?                      @map("web_view_link")
  webContentLink    String?                      @map("web_content_link")
  iconLink          String?                      @map("icon_link")
  thumbnailLink     String?                      @map("thumbnail_link")
  size              String?
  headRevisionId    String?                      @map("head_revision_id")
  md5Checksum       String?                      @map("md5_checksum")
  modifiedTime      DateTime?                    @map("modified_time")
  operatingAreaId   String?                      @map("operating_area_id") @db.Uuid
  operatingArea     OperatingArea?               @relation(fields: [operatingAreaId], references: [id], onDelete: SetNull)
  operatingFolderId String?                      @map("operating_folder_id") @db.Uuid
  operatingFolder   OperatingFolder?             @relation(fields: [operatingFolderId], references: [id], onDelete: SetNull)
  operatingTableId  String?                      @map("operating_table_id") @db.Uuid
  operatingTable    OperatingTable?              @relation(fields: [operatingTableId], references: [id], onDelete: SetNull)
  storageLocationId String?                      @map("storage_location_id") @db.Uuid
  storageLocation   StorageLocation?             @relation(fields: [storageLocationId], references: [id], onDelete: SetNull)
  knowledgeRootId   String?                      @map("knowledge_root_id") @db.Uuid
  knowledgeRoot     KnowledgeRoot?               @relation(fields: [knowledgeRootId], references: [id], onDelete: SetNull)
  syncStatus        String                       @default("pending") @map("sync_status")
  scanStatus        String                       @default("not_scanned") @map("scan_status")
  lastSyncedAt      DateTime?                    @map("last_synced_at")
  lastScannedAt     DateTime?                    @map("last_scanned_at")
  rawMetadata       Json                         @default("{}") @map("raw_metadata")
  contentSnapshots  GoogleDriveContentSnapshot[]
  createdAt         DateTime                     @default(now()) @map("created_at")
  updatedAt         DateTime                     @updatedAt @map("updated_at")

  @@unique([workspaceId, provider, externalId])
  @@index([workspaceId, parentExternalId])
  @@index([workspaceId, isFolder])
  @@index([workspaceId, operatingAreaId])
  @@index([workspaceId, operatingFolderId])
  @@index([workspaceId, operatingTableId])
  @@index([workspaceId, storageLocationId])
  @@index([workspaceId, knowledgeRootId])
  @@map("google_drive_files")
}

model GoogleDriveContentSnapshot {
  id                String          @id @default(uuid()) @db.Uuid
  workspaceId       String          @map("workspace_id") @db.Uuid
  workspace         Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  googleDriveFileId String          @map("google_drive_file_id") @db.Uuid
  googleDriveFile   GoogleDriveFile @relation(fields: [googleDriveFileId], references: [id], onDelete: Cascade)
  sourceRevisionId  String          @map("source_revision_id")
  contentKind       String          @map("content_kind")
  extractedText     String?         @map("extracted_text")
  structuredPreview Json?           @map("structured_preview")
  summary           String?
  scanStatus        String          @default("completed") @map("scan_status")
  errorCode         String?         @map("error_code")
  metadata          Json            @default("{}")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  @@unique([googleDriveFileId, sourceRevisionId])
  @@index([workspaceId, contentKind])
  @@index([workspaceId, scanStatus])
  @@map("google_drive_content_snapshots")
}

model ExternalWebhookRegistration {
  id               String               @id @default(uuid()) @db.Uuid
  workspaceId      String               @map("workspace_id") @db.Uuid
  workspace        Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  provider         String
  externalId       String               @map("external_id")
  scopeType        String               @map("scope_type")
  scopeExternalId  String?              @map("scope_external_id")
  endpointUrl      String               @map("endpoint_url")
  secretCiphertext String               @map("secret_ciphertext")
  events           Json                 @default("[]")
  status           String               @default("active")
  lastHealthAt     DateTime?            @map("last_health_at")
  lastErrorCode    String?              @map("last_error_code")
  providerEvents   ProviderEventInbox[]
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  @@unique([workspaceId, provider, externalId])
  @@index([workspaceId, provider, status])
  @@map("external_webhook_registrations")
}

model ProviderEventInbox {
  id                    String                       @id @default(uuid()) @db.Uuid
  workspaceId           String                       @map("workspace_id") @db.Uuid
  workspace             Workspace                    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  provider              String
  webhookRegistrationId String?                      @map("webhook_registration_id") @db.Uuid
  webhookRegistration   ExternalWebhookRegistration? @relation(fields: [webhookRegistrationId], references: [id], onDelete: SetNull)
  externalWebhookId     String                       @map("external_webhook_id")
  eventName             String                       @map("event_name")
  externalTaskId        String?                      @map("external_task_id")
  idempotencyKey        String                       @map("idempotency_key")
  payloadHash           String                       @map("payload_hash")
  payload               Json
  signatureVerified     Boolean                      @default(false) @map("signature_verified")
  processingStatus      String                       @default("pending") @map("processing_status")
  retryCount            Int                          @default(0) @map("retry_count")
  lastErrorCode         String?                      @map("last_error_code")
  receivedAt            DateTime                     @default(now()) @map("received_at")
  processedAt           DateTime?                    @map("processed_at")
  createdAt             DateTime                     @default(now()) @map("created_at")
  updatedAt             DateTime                     @updatedAt @map("updated_at")

  @@unique([workspaceId, provider, idempotencyKey])
  @@index([workspaceId, provider, processingStatus])
  @@index([externalWebhookId])
  @@map("provider_event_inbox")
}

model AgentEventOutbox {
  id             String    @id @default(uuid()) @db.Uuid
  workspaceId    String    @map("workspace_id") @db.Uuid
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  eventId        String?   @map("event_id") @db.Uuid
  eventType      String    @map("event_type")
  targetAgent    String?   @map("target_agent")
  scope          Json      @default("{}")
  payload        Json
  deliveryStatus String    @default("pending") @map("delivery_status")
  availableAt    DateTime  @default(now()) @map("available_at")
  deliveredAt    DateTime? @map("delivered_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([workspaceId, deliveryStatus, availableAt])
  @@index([workspaceId, eventType])
  @@map("agent_event_outbox")
}

model WorkspaceMembership {
  id          String        @id @default(uuid()) @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String        @map("user_id") @db.Uuid
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        WorkspaceRole @default(owner)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@unique([workspaceId, userId])
  @@map("workspace_memberships")
}

model Project {
  id          String     @id @default(uuid()) @db.Uuid
  workspaceId String?    @map("workspace_id") @db.Uuid
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  description String?
  status      String     @default("active")
  externalId  String?    @map("external_id")
  source      String?    @default("companycore")
  goals       Goal[]
  taskLists   TaskList[]
  tasks       Task[]
  notes       Note[]
  decisions   Decision[]
  events      Event[]
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@map("projects")
}

model Goal {
  id          String     @id @default(uuid()) @db.Uuid
  workspaceId String?    @map("workspace_id") @db.Uuid
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projectId   String?    @map("project_id") @db.Uuid
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title       String
  description String?
  status      String     @default("active")
  externalId  String?    @map("external_id")
  source      String?    @default("companycore")
  targets     Target[]
  tasks       Task[]
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@map("goals")
}

model Target {
  id           String     @id @default(uuid()) @db.Uuid
  workspaceId  String?    @map("workspace_id") @db.Uuid
  workspace    Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  goalId       String?    @map("goal_id") @db.Uuid
  goal         Goal?      @relation(fields: [goalId], references: [id], onDelete: SetNull)
  title        String
  description  String?
  metric       String?
  targetValue  Float?     @map("target_value")
  currentValue Float?     @default(0) @map("current_value")
  dueDate      DateTime?  @map("due_date")
  status       String     @default("active")
  externalId   String?    @map("external_id")
  source       String?    @default("companycore")
  tasks        Task[]
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@map("targets")
}

model TaskList {
  id          String     @id @default(uuid()) @db.Uuid
  workspaceId String?    @map("workspace_id") @db.Uuid
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projectId   String?    @map("project_id") @db.Uuid
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  name        String
  description String?
  externalId  String?    @map("external_id")
  source      String?    @default("companycore")
  tasks       Task[]
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@map("task_lists")
}

model Task {
  id          String     @id @default(uuid()) @db.Uuid
  workspaceId String?    @map("workspace_id") @db.Uuid
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projectId   String?    @map("project_id") @db.Uuid
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  goalId      String?    @map("goal_id") @db.Uuid
  goal        Goal?      @relation(fields: [goalId], references: [id], onDelete: SetNull)
  targetId    String?    @map("target_id") @db.Uuid
  target      Target?    @relation(fields: [targetId], references: [id], onDelete: SetNull)
  taskListId  String?    @map("task_list_id") @db.Uuid
  taskList    TaskList?  @relation(fields: [taskListId], references: [id], onDelete: SetNull)
  title       String
  description String?
  status      TaskStatus @default(todo)
  priority    String?
  dueDate     DateTime?  @map("due_date")
  externalId  String?    @map("external_id")
  source      String?    @default("companycore")
  notes       Note[]
  events      Event[]
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@unique([workspaceId, source, externalId])
  @@map("tasks")
}

model Client {
  id           String        @id @default(uuid()) @db.Uuid
  workspaceId  String?       @map("workspace_id") @db.Uuid
  workspace    Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name         String
  companyName  String?       @map("company_name")
  email        String?
  phone        String?
  status       String        @default("active")
  externalId   String?       @map("external_id")
  source       String?       @default("companycore")
  deals        Deal[]
  interactions Interaction[]
  notes        Note[]
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@map("clients")
}

model PipelineStage {
  id          String     @id @default(uuid()) @db.Uuid
  workspaceId String?    @map("workspace_id") @db.Uuid
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  position    Int        @default(0)
  externalId  String?    @map("external_id")
  source      String?    @default("companycore")
  deals       Deal[]
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@map("pipeline_stages")
}

model Deal {
  id              String         @id @default(uuid()) @db.Uuid
  workspaceId     String?        @map("workspace_id") @db.Uuid
  workspace       Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  clientId        String?        @map("client_id") @db.Uuid
  client          Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  pipelineStageId String?        @map("pipeline_stage_id") @db.Uuid
  pipelineStage   PipelineStage? @relation(fields: [pipelineStageId], references: [id], onDelete: SetNull)
  title           String
  value           Decimal?       @db.Decimal(12, 2)
  currency        String?        @default("PLN")
  status          DealStatus     @default(open)
  externalId      String?        @map("external_id")
  source          String?        @default("companycore")
  notes           Note[]
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@map("deals")
}

model Interaction {
  id          String     @id @default(uuid()) @db.Uuid
  workspaceId String?    @map("workspace_id") @db.Uuid
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
