generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  todo
  in_progress
  blocked
  done
  archived
}

enum DealStatus {
  open
  won
  lost
  archived
}

enum AgentStatus {
  active
  paused
  retired
}

enum WorkforceEntityType {
  human
  agent
}

enum WorkforceEntityStatus {
  active
  inactive
  paused
  archived
}

enum WorkforceRuntimeMode {
  manual
  semi_autonomous
  autonomous
}

enum WorkforcePersonalityProfile {
  analytical
  creative
  executive
  supportive
  researcher
  custom
}

enum WorkspaceRole {
  owner
}

enum OperatingStatus {
  draft
  active
  paused
  archived
  retired
  deprecated
}

enum CompanyRoleType {
  human
  agent
  system
}

enum RiskLevel {
  low
  medium
  high
  critical
}

enum TriggerType {
  manual
  schedule
  webhook
  clickup_status_change
  drive_file_created
  github_push
  n8n_webhook
  agent_decision
  system_event
}

enum ProcedureStepType {
  manual
  automated
  agent
  human_review
  integration_call
}

enum AdapterProvider {
  clickup
  google_drive
  gmail
  github
  coolify
  n8n
  custom
}

enum AdapterAuthType {
  api_key
  oauth
  webhook_secret
  service_account
  none
  custom
}

enum AdapterConnectionStatus {
  configured
  connected
  degraded
  disconnected
  blocked
}

enum AdapterHealthStatus {
  unknown
  healthy
  degraded
  failed
}

enum ActorType {
  user
  agent
  system
  integration
}

enum PipelineRunStatus {
  pending
  running
  blocked
  completed
  failed
  cancelled
}

enum StageRunStatus {
  pending
  running
  blocked
  completed
  failed
  skipped
}

enum ApprovalStatus {
  pending
  approved
  rejected
  expired
}

enum VerificationStatus {
  not_started
  pending
  passed
  failed
  waived
}

enum ChecklistTargetType {
  task
  pipeline_stage
  procedure
  pipeline_run
  stage_run
}

enum EnforcementMode {
  soft_warning
  block
  require_approval
  log_only
}

enum AutomationRuleStatus {
  draft
  active
  paused
  archived
}

enum DependencyStatus {
  active
  blocked
  resolved
  archived
}

model User {
  id              String                @id @default(uuid()) @db.Uuid
  email           String                @unique
  name            String?
  passwordHash    String                @map("password_hash")
  ownedWorkspaces Workspace[]           @relation("WorkspaceOwner")
  memberships     WorkspaceMembership[]
  approvalDecisions Approval[]          @relation("ApprovalApproverUser")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  @@map("users")
}

model Workspace {
  id                           String                        @id @default(uuid()) @db.Uuid
  name                         String
  ownerUserId                  String                        @map("owner_user_id") @db.Uuid
  owner                        User                          @relation("WorkspaceOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  memberships                  WorkspaceMembership[]
  apiKeys                      ApiKey[]
  integrationSettings          IntegrationSetting[]
  projects                     Project[]
  goals                        Goal[]
  targets                      Target[]
  taskLists                    TaskList[]
  tasks                        Task[]
  clients                      Client[]
  pipelineStages               PipelineStage[]
  deals                        Deal[]
  interactions                 Interaction[]
  notes                        Note[]
  decisions                    Decision[]
  agents                       Agent[]
  workforceEntities            WorkforceEntity[]
  agentLogs                    AgentLog[]
  events                       Event[]
  processes                    Process[]
  pipelines                    Pipeline[]
  procedures                   Procedure[]
  companyRoles                 CompanyRole[]
  universalResources           Resource[]
  toolAdapters                 ToolAdapter[]
  integrationCapabilities      IntegrationCapability[]
  standards                    Standard[]
  pipelineRuns                 PipelineRun[]
  stageRuns                    StageRun[]
  approvals                    Approval[]
  auditLogs                    AuditLog[]
  checklistTemplates           ChecklistTemplate[]
  checklistItems               ChecklistItem[]
  acceptanceCriteria           AcceptanceCriterion[]
  policies                     Policy[]
  metrics                      Metric[]
  risks                        Risk[]
  controls                     Control[]
  knowledgeItems               KnowledgeItem[]
  decisionLogs                 DecisionLog[]
  automationRules              AutomationRule[]
  triggers                     Trigger[]
  artifacts                    Artifact[]
  dependencies                 Dependency[]
  businessFunctions            BusinessFunction[]
  stakeholders                 Stakeholder[]
  operatingAreas               OperatingArea[]
  operatingFolders             OperatingFolder[]
  operatingTables              OperatingTable[]
  externalContainerMappings    ExternalContainerMapping[]
  externalFieldMappings        ExternalFieldMapping[]
  storageLocations             StorageLocation[]
  knowledgeRoots               KnowledgeRoot[]
  automationDefinitions        AutomationDefinition[]
  googleDriveFiles             GoogleDriveFile[]
  googleDriveContentSnapshots  GoogleDriveContentSnapshot[]
  externalWebhookRegistrations ExternalWebhookRegistration[]
  providerEventInbox           ProviderEventInbox[]
  agentEventOutbox             AgentEventOutbox[]
  createdAt                    DateTime                      @default(now()) @map("created_at")
  updatedAt                    DateTime                      @updatedAt @map("updated_at")

  @@map("workspaces")
}

model OperatingArea {
  id                        String                     @id @default(uuid()) @db.Uuid
  workspaceId               String                     @map("workspace_id") @db.Uuid
  workspace                 Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  key                       String
  name                      String
  description               String?
  position                  Int                        @default(0)
  isSystem                  Boolean                    @default(false) @map("is_system")
  folders                   OperatingFolder[]
  tables                    OperatingTable[]
  externalContainerMappings ExternalContainerMapping[]
  storageLocations          StorageLocation[]
  knowledgeRoots            KnowledgeRoot[]
  googleDriveFiles          GoogleDriveFile[]
  automationDefinitions     AutomationDefinition[]
  createdAt                 DateTime                   @default(now()) @map("created_at")
  updatedAt                 DateTime                   @updatedAt @map("updated_at")

  @@unique([workspaceId, key])
  @@index([workspaceId, position])
  @@map("operating_areas")
}

model OperatingFolder {
  id                        String                     @id @default(uuid()) @db.Uuid
  workspaceId               String                     @map("workspace_id") @db.Uuid
  workspace                 Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  areaId                    String                     @map("area_id") @db.Uuid
  area                      OperatingArea              @relation(fields: [areaId], references: [id], onDelete: Cascade)
  key                       String
  name                      String
  description               String?
  source                    String                     @default("companycore")
  externalId                String?                    @map("external_id")
  tables                    OperatingTable[]
  externalContainerMappings ExternalContainerMapping[]
  storageLocations          StorageLocation[]
  knowledgeRoots            KnowledgeRoot[]
  googleDriveFiles          GoogleDriveFile[]
  automationDefinitions     AutomationDefinition[]
  createdAt                 DateTime                   @default(now()) @map("created_at")
  updatedAt                 DateTime                   @updatedAt @map("updated_at")

  @@unique([workspaceId, key])
  @@unique([workspaceId, source, externalId])
  @@index([workspaceId, areaId])
  @@map("operating_folders")
}

model OperatingTable {
  id                        String                     @id @default(uuid()) @db.Uuid
  workspaceId               String                     @map("workspace_id") @db.Uuid
  workspace                 Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  areaId                    String                     @map("area_id") @db.Uuid
  area                      OperatingArea              @relation(fields: [areaId], references: [id], onDelete: Cascade)
  folderId                  String?                    @map("folder_id") @db.Uuid
  folder                    OperatingFolder?           @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tableName                 String                     @map("table_name")
  apiSlug                   String                     @map("api_slug")
  name                      String
  description               String?
  source                    String                     @default("companycore")
  externalId                String?                    @map("external_id")
  syncPolicy                Json                       @default("{}") @map("sync_policy")
  externalContainerMappings ExternalContainerMapping[]
  externalFieldMappings     ExternalFieldMapping[]
  storageLocations          StorageLocation[]
  knowledgeRoots            KnowledgeRoot[]
  googleDriveFiles          GoogleDriveFile[]
  automationDefinitions     AutomationDefinition[]
  createdAt                 DateTime                   @default(now()) @map("created_at")
  updatedAt                 DateTime                   @updatedAt @map("updated_at")

  @@unique([workspaceId, apiSlug])
  @@unique([workspaceId, tableName])
  @@unique([workspaceId, source, externalId])
  @@index([workspaceId, areaId])
  @@index([workspaceId, folderId])
  @@map("operating_tables")
}

model CompanyRole {
  id                 String          @id @default(uuid()) @db.Uuid
  workspaceId        String          @map("workspace_id") @db.Uuid
  workspace          Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name               String
  type               CompanyRoleType @default(agent)
  responsibilities   Json            @default("[]")
  permissions        Json            @default("[]")
  allowedTools       Json            @default("[]") @map("allowed_tools")
  escalationTargetId String?         @map("escalation_target_id") @db.Uuid
  escalationTarget   CompanyRole?    @relation("CompanyRoleEscalation", fields: [escalationTargetId], references: [id], onDelete: SetNull)
  escalatedRoles     CompanyRole[]   @relation("CompanyRoleEscalation")
  defaultPolicies    Json            @default("[]") @map("default_policies")
  ownedProcesses     Process[]       @relation("ProcessOwnerRole")
  defaultPipelines   Pipeline[]      @relation("PipelineDefaultOwnerRole")
  assignedStages     PipelineStage[] @relation("PipelineStageAssignedRole")
  ownedProcedures    Procedure[]     @relation("ProcedureOwnerRole")
  ownedResources     Resource[]      @relation("ResourceOwnerRole")
  ownedStandards     Standard[]      @relation("StandardOwnerRole")
  toolAdapters       ToolAdapter[]   @relation("ToolAdapterOwnerRole")
  approverApprovals  Approval[]      @relation("ApprovalApproverRole")
  escalatedPolicies  Policy[]        @relation("PolicyEscalationRole")
  ownedMetrics       Metric[]        @relation("MetricOwnerRole")
  ownedControls      Control[]       @relation("ControlOwnerRole")
  accountableFunctions BusinessFunction[] @relation("BusinessFunctionAccountableRole")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  @@unique([workspaceId, name])
  @@index([workspaceId, type])
  @@map("company_roles")
}

model Process {
  id                 String          @id @default(uuid()) @db.Uuid
  familyId           String          @default(uuid()) @map("family_id") @db.Uuid
  workspaceId        String          @map("workspace_id") @db.Uuid
  workspace          Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name               String
  description        String?
  ownerRoleId        String?         @map("owner_role_id") @db.Uuid
  ownerRole          CompanyRole?    @relation("ProcessOwnerRole", fields: [ownerRoleId], references: [id], onDelete: SetNull)
  department         String?
  category           String?
  status             OperatingStatus @default(draft)
  version            Int             @default(1)
  maturityLevel      String          @default("initial") @map("maturity_level")
  relatedPolicies    Json            @default("[]") @map("related_policies")
  relatedMetrics     Json            @default("[]") @map("related_metrics")
  pipelines          Pipeline[]
  procedures         Procedure[]
  resources          Resource[]
  policies           Policy[]
  metrics            Metric[]
  risks              Risk[]
  knowledgeItems     KnowledgeItem[]
  decisionLogs       DecisionLog[]
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  @@unique([workspaceId, name, version])
  @@index([workspaceId, status])
  @@index([workspaceId, familyId, status])
  @@index([workspaceId, department])
  @@map("processes")
}

model Pipeline {
  id                 String          @id @default(uuid()) @db.Uuid
  familyId           String          @default(uuid()) @map("family_id") @db.Uuid
  workspaceId        String          @map("workspace_id") @db.Uuid
  workspace          Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  processId          String?         @map("process_id") @db.Uuid
  process            Process?        @relation(fields: [processId], references: [id], onDelete: SetNull)
  name               String
  purpose            String
  triggerType        TriggerType     @default(manual) @map("trigger_type")
  inputSchema        Json            @default("{}") @map("input_schema")
  outputSchema       Json            @default("{}") @map("output_schema")
  defaultOwnerRoleId String?         @map("default_owner_role_id") @db.Uuid
  defaultOwnerRole   CompanyRole?    @relation("PipelineDefaultOwnerRole", fields: [defaultOwnerRoleId], references: [id], onDelete: SetNull)
  status             OperatingStatus @default(draft)
  version            Int             @default(1)
  isAutomatable      Boolean         @default(false) @map("is_automatable")
  riskLevel          RiskLevel       @default(medium) @map("risk_level")
  stages             PipelineStage[]
  runs               PipelineRun[]
  metrics            Metric[]
  risks              Risk[]
  knowledgeItems     KnowledgeItem[]
  decisionLogs       DecisionLog[]
  automationRules    AutomationRule[]
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  @@unique([workspaceId, name, version])
  @@index([workspaceId, status])
  @@index([workspaceId, familyId, status])
  @@index([workspaceId, processId])
  @@map("pipelines")
}

model Procedure {
  id                 String          @id @default(uuid()) @db.Uuid
  familyId           String          @default(uuid()) @map("family_id") @db.Uuid
  workspaceId        String          @map("workspace_id") @db.Uuid
  workspace          Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  processId          String?         @map("process_id") @db.Uuid
  process            Process?        @relation(fields: [processId], references: [id], onDelete: SetNull)
  name               String
  purpose            String
  scope              String?
  ownerRoleId        String?         @map("owner_role_id") @db.Uuid
  ownerRole          CompanyRole?    @relation("ProcedureOwnerRole", fields: [ownerRoleId], references: [id], onDelete: SetNull)
  version            Int             @default(1)
  status             OperatingStatus @default(draft)
  requiredTools      Json            @default("[]") @map("required_tools")
  requiredPermissions Json           @default("[]") @map("required_permissions")
  expectedResult     String?         @map("expected_result")
  qualityStandardId  String?         @map("quality_standard_id") @db.Uuid
  qualityStandard    Standard?       @relation(fields: [qualityStandardId], references: [id], onDelete: SetNull)
  stages             PipelineStage[]
  steps              ProcedureStep[]
  policies           Policy[]
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  @@unique([workspaceId, name, version])
  @@index([workspaceId, status])
  @@index([workspaceId, familyId, status])
  @@index([workspaceId, processId])
  @@map("procedures")
}

model ProcedureStep {
  id                    String            @id @default(uuid()) @db.Uuid
  procedureId           String            @map("procedure_id") @db.Uuid
  procedure             Procedure         @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  stepOrder             Int               @map("step_order")
  instruction           String
  stepType              ProcedureStepType @default(manual) @map("step_type")
  requiredToolAdapterId String?           @map("required_tool_adapter_id") @db.Uuid
  requiredToolAdapter   ToolAdapter?      @relation(fields: [requiredToolAdapterId], references: [id], onDelete: SetNull)
  expectedInput         Json              @default("{}") @map("expected_input")
  expectedOutput        Json              @default("{}") @map("expected_output")
  validationRule        Json              @default("{}") @map("validation_rule")
  rollbackInstruction   String?           @map("rollback_instruction")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  @@unique([procedureId, stepOrder])
  @@index([procedureId])
  @@map("procedure_steps")
}

model Resource {
  id               String       @id @default(uuid()) @db.Uuid
  workspaceId      String       @map("workspace_id") @db.Uuid
  workspace        Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type             String
  externalProvider String?      @map("external_provider")
  externalId       String?      @map("external_id")
  name             String
  url              String?
  metadata         Json         @default("{}")
  ownerRoleId      String?      @map("owner_role_id") @db.Uuid
  ownerRole        CompanyRole? @relation("ResourceOwnerRole", fields: [ownerRoleId], references: [id], onDelete: SetNull)
  accessLevel      String       @default("workspace") @map("access_level")
  relatedProjectId String?      @map("related_project_id") @db.Uuid
  relatedProject   Project?     @relation(fields: [relatedProjectId], references: [id], onDelete: SetNull)
  relatedProcessId String?      @map("related_process_id") @db.Uuid
  relatedProcess   Process?     @relation(fields: [relatedProcessId], references: [id], onDelete: SetNull)
  artifacts        Artifact[]
  dependenciesFrom Dependency[] @relation("DependencyFromResource")
  dependenciesTo   Dependency[] @relation("DependencyToResource")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@unique([workspaceId, externalProvider, externalId])
  @@index([workspaceId, type])
  @@index([workspaceId, relatedProjectId])
  @@index([workspaceId, relatedProcessId])
  @@map("resources")
}

model ToolAdapter {
  id                String                  @id @default(uuid()) @db.Uuid
  workspaceId       String                  @map("workspace_id") @db.Uuid
  workspace         Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  provider          AdapterProvider
  name              String
  authType          AdapterAuthType         @map("auth_type")
  connectionStatus  AdapterConnectionStatus @default(disconnected) @map("connection_status")
  capabilities      IntegrationCapability[]
  rateLimitInfo     Json                    @default("{}") @map("rate_limit_info")
  lastSyncAt        DateTime?               @map("last_sync_at")
  configSchema      Json                    @default("{}") @map("config_schema")
  healthStatus      AdapterHealthStatus     @default(unknown) @map("health_status")
  ownerRoleId       String?                 @map("owner_role_id") @db.Uuid
  ownerRole         CompanyRole?            @relation("ToolAdapterOwnerRole", fields: [ownerRoleId], references: [id], onDelete: SetNull)
  procedureSteps    ProcedureStep[]
  auditLogs         AuditLog[]
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")

  @@unique([workspaceId, provider])
  @@index([workspaceId, connectionStatus])
  @@map("tool_adapters")
}

model IntegrationCapability {
  id                  String      @id @default(uuid()) @db.Uuid
  workspaceId         String      @map("workspace_id") @db.Uuid
  workspace           Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  toolAdapterId       String      @map("tool_adapter_id") @db.Uuid
  toolAdapter         ToolAdapter @relation(fields: [toolAdapterId], references: [id], onDelete: Cascade)
  capabilityKey       String      @map("capability_key")
  requiredPermissions Json        @default("[]") @map("required_permissions")
  inputSchema         Json        @default("{}") @map("input_schema")
  outputSchema        Json        @default("{}") @map("output_schema")
  riskLevel           RiskLevel   @default(medium) @map("risk_level")
  requiresApproval    Boolean     @default(false) @map("requires_approval")
  auditRequired       Boolean     @default(true) @map("audit_required")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  @@unique([toolAdapterId, capabilityKey])
  @@index([workspaceId, capabilityKey])
  @@map("integration_capabilities")
}

model Standard {
  id               String       @id @default(uuid()) @db.Uuid
  workspaceId      String       @map("workspace_id") @db.Uuid
  workspace        Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name             String
  category         String
  description      String?
  checklistId      String?      @map("checklist_id") @db.Uuid
  validationMethod String?      @map("validation_method")
  ownerRoleId      String?      @map("owner_role_id") @db.Uuid
  ownerRole        CompanyRole? @relation("StandardOwnerRole", fields: [ownerRoleId], references: [id], onDelete: SetNull)
  status           OperatingStatus @default(active)
  version          Int          @default(1)
  procedures       Procedure[]
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@index([workspaceId, status])
  @@unique([workspaceId, name, version])
  @@map("standards")
}

model PipelineRun {
  id                String            @id @default(uuid()) @db.Uuid
  workspaceId       String            @map("workspace_id") @db.Uuid
  workspace         Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pipelineId        String            @map("pipeline_id") @db.Uuid
  pipeline          Pipeline          @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  initiatedByType   ActorType         @map("initiated_by_type")
  initiatedById     String?           @map("initiated_by_id")
  status            PipelineRunStatus @default(pending)
  currentStageId    String?           @map("current_stage_id") @db.Uuid
  currentStage      PipelineStage?    @relation("PipelineRunCurrentStage", fields: [currentStageId], references: [id], onDelete: SetNull)
  inputPayload      Json              @default("{}") @map("input_payload")
  outputPayload     Json              @default("{}") @map("output_payload")
  startedAt         DateTime?         @map("started_at")
  completedAt       DateTime?         @map("completed_at")
  errorState        Json?             @map("error_state")
  linkedTaskIds     Json              @default("[]") @map("linked_task_ids")
  linkedDocumentIds Json              @default("[]") @map("linked_document_ids")
  linkedClientId    String?           @map("linked_client_id") @db.Uuid
  linkedClient      Client?           @relation(fields: [linkedClientId], references: [id], onDelete: SetNull)
  linkedProjectId   String?           @map("linked_project_id") @db.Uuid
  linkedProject     Project?          @relation(fields: [linkedProjectId], references: [id], onDelete: SetNull)
  correlationId     String            @map("correlation_id")
  stageRuns         StageRun[]
  approvals         Approval[]
  auditLogs         AuditLog[]
  acceptanceCriteria AcceptanceCriterion[]
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  @@unique([workspaceId, correlationId])
  @@index([workspaceId, pipelineId, status])
  @@index([workspaceId, currentStageId])
  @@index([workspaceId, linkedClientId])
  @@index([workspaceId, linkedProjectId])
  @@map("pipeline_runs")
}

model StageRun {
  id                 String         @id @default(uuid()) @db.Uuid
  workspaceId        String         @map("workspace_id") @db.Uuid
  workspace          Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pipelineRunId      String         @map("pipeline_run_id") @db.Uuid
  pipelineRun        PipelineRun    @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)
  pipelineStageId    String         @map("pipeline_stage_id") @db.Uuid
  pipelineStage      PipelineStage  @relation(fields: [pipelineStageId], references: [id], onDelete: Restrict)
  assignedActorType  ActorType?     @map("assigned_actor_type")
  assignedActorId    String?        @map("assigned_actor_id")
  status             StageRunStatus @default(pending)
  inputPayload       Json           @default("{}") @map("input_payload")
  outputPayload      Json           @default("{}") @map("output_payload")
  logs               Json           @default("[]")
  startedAt          DateTime?      @map("started_at")
  completedAt        DateTime?      @map("completed_at")
  validationResult   Json?          @map("validation_result")
  approvalStatus     ApprovalStatus @default(pending) @map("approval_status")
  approvals          Approval[]
  auditLogs          AuditLog[]
  acceptanceCriteria AcceptanceCriterion[]
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  @@unique([pipelineRunId, pipelineStageId])
  @@index([workspaceId, status])
  @@index([workspaceId, pipelineStageId])
  @@map("stage_runs")
}

model Approval {
  id                 String         @id @default(uuid()) @db.Uuid
  workspaceId        String         @map("workspace_id") @db.Uuid
  workspace          Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requestedByType    ActorType      @map("requested_by_type")
  requestedById      String?        @map("requested_by_id")
  requestedForAction String         @map("requested_for_action")
  resourceType       String         @map("resource_type")
  resourceId         String?        @map("resource_id")
  riskLevel          RiskLevel      @default(medium) @map("risk_level")
  approverRoleId     String?        @map("approver_role_id") @db.Uuid
  approverRole       CompanyRole?   @relation("ApprovalApproverRole", fields: [approverRoleId], references: [id], onDelete: SetNull)
  approverUserId     String?        @map("approver_user_id") @db.Uuid
  approverUser       User?          @relation("ApprovalApproverUser", fields: [approverUserId], references: [id], onDelete: SetNull)
  status             ApprovalStatus @default(pending)
  decisionReason     String?        @map("decision_reason")
