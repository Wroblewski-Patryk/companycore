NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://companycore:companycore@localhost:5432/companycore?schema=public
SEED_API_KEY=dev-companycore-key
AUTH_TOKEN_SECRET=dev-companycore-auth-secret-change-me
API_KEY_HASH_SECRET=dev-companycore-api-key-hash-secret-change-me
INTEGRATION_SECRET_KEY=dev-companycore-integration-secret-change-me
SEED_OWNER_EMAIL=owner@example.com
SEED_OWNER_PASSWORD=change-me-local-password
SEED_WORKSPACE_NAME=LuckySparrow

# Operator-only ClickUp bootstrap values for npm run clickup:bootstrap.
# Do not commit real provider tokens. In production, prefer one-time shell or
# Coolify secret injection only for the bootstrap command.
COMPANYCORE_BASE_URL=http://localhost:3000
COMPANYCORE_PUBLIC_API_BASE_URL=http://localhost:3000
COMPANYCORE_ALLOWED_ORIGINS=http://localhost:3000
COMPANYCORE_API_KEY=dev-companycore-key
COMPANYCORE_BUILD_COMMIT=local
COMPANYCORE_BUILD_IMAGE=local
# Coolify can expose the current Git revision through SOURCE_COMMIT. Keep
# COMPANYCORE_BUILD_COMMIT mapped to it in production, or rely on
# docker-compose.coolify.yml when SOURCE_COMMIT is available to the stack.
SOURCE_COMMIT=local
COOLIFY_CONTAINER_NAME=companycore-local
CLICKUP_API_TOKEN=replace-with-clickup-token
CLICKUP_TEAM_ID=replace-with-clickup-team-id
CLICKUP_LIST_IDS=replace-with-clickup-list-id
CLICKUP_IMPORT_MODE=merge
CLICKUP_MAINTENANCE_INTERVAL_MINUTES=15

# Operator-only Google Drive smoke/bootstrap values.
# Do not commit real OAuth tokens. Google Drive uses workspace-owned encrypted
# OAuth material stored through /v1/integration-settings/google_drive.
GOOGLE_DRIVE_ROOT_FOLDER_IDS=replace-with-drive-folder-id
GOOGLE_DRIVE_SELECTED_FOLDER_IDS=replace-with-drive-folder-id
GOOGLE_DRIVE_IMPORT_MODE=inspect_only
GOOGLE_OAUTH_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=replace-with-google-oauth-client-secret
